# ── Pyth Insight — environment variables ─────────────────────────────────────
# Copy this file to .env.local and fill in the values you need.
# None of these are required to run the app locally — see notes below.

# ── AI Analyst ────────────────────────────────────────────────────────────────
# At least one AI key is needed for the AI Analyst page.
# Gemini (free tier at aistudio.google.com) is the primary; Claude is fallback.
GEMINI_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...

# ── Pyth Pro / Benchmarks API ─────────────────────────────────────────────────
# Optional. If set, the CI Calibration engine falls back to benchmarks.pyth.network
# when Hermes historical snapshots are unavailable.
# Get a key at https://pyth.network/pro
PYTH_PRO_API_KEY=

# ── Entropy / RPC ─────────────────────────────────────────────────────────────
# Optional. Alchemy RPC URL for Base mainnet — used by the entropy route to
# query a wider block range when looking for RevealedWithCallback events.
# Format: https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_RPC_URL=

# Optional. BaseScan or Etherscan API key — used by the entropy route to
# query the Entropy contract event index. A BaseScan key (basescan.org) is free.
# Note: Etherscan.io keys require a paid plan for Base (chainid=8453).
BASESCAN_API_KEY=

# ── GitHub link (shown in the navbar) ────────────────────────────────────────
# Set this to your actual repo URL so the GitHub link in the nav goes to the right place.
NEXT_PUBLIC_GITHUB_URL=https://github.com/DE-LIGHTPRO/pyth-insight
